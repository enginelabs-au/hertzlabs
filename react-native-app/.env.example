# ─────────────────────────────────────────────────────────────────────────────
# Hertz Labs — environment variables
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Get keys from: RevenueCat Dashboard → Project → API keys → Public app keys
#
# SANDBOX TESTING FLOW:
#  1. Create a free RevenueCat account at https://app.revenuecat.com
#  2. Add a new App (platform: App Store / Google Play).
#  3. In App Store Connect, create 3 products matching these identifiers:
#       hertzlabs_premium_monthly   (Auto-Renewable Subscription, $4.99/mo, 7-day trial)
#       hertzlabs_premium_annual    (Auto-Renewable Subscription, $24.99/yr, 7-day trial)
#       hertzlabs_lifetime_ultra    (Non-Consumable, $19.99 one-time)
#     Do NOT reuse hertzlabs_monthly_premium / hertzlabs_annual_premium — those IDs
#     were burned when created as Consumables (Apple never recycles Product IDs).
#  4. In the RevenueCat dashboard, create:
#       - Entitlement ID: premium  (maps to all 3 products)
#       - Offering ID:    default
#       - 3 packages: $rc_monthly, $rc_annual, $rc_lifetime
#  5. Paste the iOS public SDK key below (starts with "appl_…" for production
#     or "rcb_…" for a test/sandbox key).
#  6. On device: sign in to a Sandbox Tester Apple ID
#     (App Store Connect → Users & Access → Sandbox Testers).
#  7. Tap any "Upgrade to Premium" button in the app → paywall appears →
#     tap "Start Free Trial" → iOS sandbox purchase sheet → confirm with
#     sandbox tester password → entitlement activates immediately.
#
# NOTE: FORCED_V1_TEST_UNLOCK is set to `false` in
#       src/monetization/isPremiumUnlocked.ts — features are gated.
#       Set it back to `true` ONLY for local development without a RC key.

# App Store public SDK key (RevenueCat → Apps → iOS → Public API key, starts with appl_)
REVENUECAT_API_KEY_IOS=appl_REPLACE_WITH_YOUR_IOS_KEY
REVENUECAT_API_KEY_ANDROID=goog_REPLACE_WITH_YOUR_ANDROID_KEY

# Secret key for server-side RC API (starts with sk_). Used by scripts/audit-revenuecat-setup.mjs
# NEVER ship this in the mobile app bundle.
REVENUECAT_API_KEY_WEB=sk_REPLACE_WITH_YOUR_V2_SECRET_KEY

# Entitlement ID — must match what you created in the RevenueCat dashboard.
REVENUECAT_ENTITLEMENT_ID=premium

# ── App Store Connect API (optional — for local automation scripts) ─────────────
# From App Store Connect → Users and Access → Integrations
# Upload the .p8 + Key ID + Issuer ID in RevenueCat dashboard (required for live prices).
APPLE_CONNECT_KEY_ID=REPLACE_WITH_10_CHAR_KEY_ID
APPLE_CONNECT_ISSUER_ID=REPLACE_WITH_UUID_ISSUER_ID
APPLE_CONNECT_API_KEY=REPLACE_WITH_APP_STORE_CONNECT_API_P8_CONTENTS
APPLE_CONNECT_SUBSCRIPTION_KEY=REPLACE_WITH_IN_APP_PURCHASE_P8_CONTENTS

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Optional: used by the native HertzAI TurboModule for live AI suggestions.
# Also set in ios/HertzLabsBinauralBeats/GenerativeAI-Info.plist as API_KEY.
GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_KEY
