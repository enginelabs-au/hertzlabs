# Copy to `.env` in this directory (gitignored). Babel inlines RevenueCat keys at bundle time.
# Run: npm run sync-secrets (writes xor-v1 Gemini plist for iOS + Swift apps).

# RevenueCat public SDK keys (dashboard → Project → API keys).
REVENUECAT_API_KEY_IOS=
REVENUECAT_API_KEY_ANDROID=

# Entitlement identifier slug in RevenueCat (default: pro).
REVENUECAT_ENTITLEMENT_ID=pro

# Gemini — synced to GenerativeAI-Info.plist by npm run sync-secrets (gitignored).
GEMINI_API_KEY=
